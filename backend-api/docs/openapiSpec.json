          "quantity": { "type": "integer", "example": 2 }
        },
        "required": ["product_id", "quantity"]
      },
      "CartItemDetailed": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int32", "example": 1 },
          "cart_id": { "type": "integer", "format": "int32", "example": 1 },
          "product_id": { "type": "integer", "format": "int32", "example": 1 },
          "quantity": { "type": "integer", "example": 2 },
