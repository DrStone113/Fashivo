{
  "openapi": "3.1.1",
  "info": {
    "title": "Fashivo - Fashion E-commerce Website API",
    "version": "1.0.0",
    "description": "API for Fashivo fashion e-commerce website",
    "contact": {
      "name": "Huỳnh Thanh Nhuận, Thạch Nguyễn Khang",
      "email": "khangb2205987@student.ctu.edu.vn"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/v1/product": {
      "get": {
        "summary": "Get products by filter",
        "description": "Get products by filter",
        "operationId": "getProductsByFilter",
        "parameters": [
          {
            "in": "query",
            "name": "name",
            "schema": {
              "type": "string"
            },
            "description": "Filter by product name"
          },
          {
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string"
            },
            "description": "Filter by product type"
          },
          {
            "in": "query",
            "name": "available",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by product availability (true/false)"
          },
          {
            "$ref": "#/components/parameters/limitParam"
          },
          {
            "$ref": "#/components/parameters/pageParam"
          }
        ],
        "tags": [
          "products"
        ],
        "responses": {
          "200": {
            "description": "A list of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "products": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Product"
                          }
                        },
                        "metadata": {
                          "$ref": "#/components/schemas/PaginationMetadata"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new product",
        "description": "Create a new product",
        "operationId": "createProduct",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Product type (e.g., Apparel, Footwear)",
                    "example": "Apparel"
                  },
                  "name": {
                    "type": "string",
                    "description": "Product name",
                    "example": "Elegant Silk Scarf"
                  },
                  "description": {
                    "type": "string",
                    "description": "Product description",
                    "example": "A luxurious silk scarf made from 100% pure silk."
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "description": "Product price",
                    "example": 49.99
                  },
                  "stock": {
                    "type": "boolean",
                    "description": "Product availability (true for in stock, false for out of stock)",
                    "example": true
                  },
                  "imageFile": {
                    "type": "string",
                    "format": "binary",
                    "description": "Product image file to upload"
                  }
                },
                "required": ["type", "name", "price", "stock", "imageFile"]
              }
            }
          }
        },
        "tags": [
          "products"
        ],
        "responses": {
          "201": {
            "description": "A new product",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "product": {
                          "$ref": "#/components/schemas/Product"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete all products",
        "description": "Delete all products",
        "operationId": "deleteAllProducts",
        "tags": [
          "products"
        ],
        "responses": {
          "204": {
            "description": "All products deleted",
            "$ref": "#/components/responses/200NoData"
          }
        }
      }
    },
    "/api/v1/product/{id}": {
      "get": {
        "summary": "Get product by ID",
        "description": "Get product by ID",
        "operationId": "getProduct",
        "parameters": [
          {
            "$ref": "#/components/parameters/productIdParam"
          }
        ],
        "tags": [
          "products"
        ],
        "responses": {
          "200": {
            "description": "A product",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "product": {
                          "$ref": "#/components/schemas/Product"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update product by ID",
        "description": "Update product by ID",
        "operationId": "updateProduct",
        "parameters": [
          {
            "$ref": "#/components/parameters/productIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Product type (e.g., Apparel, Footwear)",
                    "example": "Apparel"
                  },
                  "name": {
                    "type": "string",
                    "description": "Product name",
                    "example": "Elegant Silk Scarf"
                  },
                  "description": {
                    "type": "string",
                    "description": "Product description",
                    "example": "A luxurious silk scarf made from 100% pure silk."
                  },
                  "price": {
                    "type": "number",
                    "format": "float",
                    "description": "Product price",
                    "example": 49.99
                  },
                  "stock": {
                    "type": "boolean",
                    "description": "Product availability (true for in stock, false for out of stock)",
                    "example": true
                  },
                  "imageFile": {
                    "type": "string",
                    "format": "binary",
                    "description": "Product image file to upload"
                  }
                },
                "required": ["type", "name", "price", "stock", "imageFile"]
              }
            }
          }
        },
        "tags": [
          "products"
        ],
        "responses": {
          "200": {
            "description": "An updated product",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "The response status",
                      "enum": [
                        "success"
                      ]
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "product": {
                          "$ref": "#/components/schemas/Product"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete product by ID",
        "description": "Delete product by ID",
        "operationId": "deleteProduct",
        "parameters": [
          {
            "$ref": "#/components/parameters/productIdParam"
          }
        ],
        "tags": [
          "products"
        ],
        "responses": {
          "204": {
            "description": "Product deleted",
            "$ref": "#/components/responses/200NoData"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true,
            "description": "Product ID (serial)"
          },
          "name": {
            "type": "string",
            "description": "Product name",
            "example": "Elegant Silk Scarf"
          },
          "type": {
            "type": "string",
            "description": "Product type",
            "example": "Apparel"
          },
          "description": {
            "type": "string",
            "description": "Product description",
            "example": "A luxurious silk scarf made from 100% pure silk."
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Product price",
            "example": 49.99
          },
          "available": {
            "type": "boolean",
            "default": true,
            "description": "Product availability (true for in stock, false for out of stock)",
            "example": true
          },
          "image_url": {
            "type": "string",
            "readOnly": true,
            "description": "Product image URL path",
            "example": "/public/img/products/product-12345.jpeg"
          }
          // Loại bỏ 'imageFile' khỏi schemas/Product vì nó chỉ là input, không phải thuộc tính của Product
        }
      },
      "PaginationMetadata": {
        "type": "object",
        "properties": {
          "totalRecords": {
            "type": "integer",
            "default": 0,
            "description": "The total number of records"
          },
          "firstPage": {
            "type": "integer",
            "default": 1,
            "description": "The first page"
          },
          "lastPage": {
            "type": "integer",
            "default": 1,
            "description": "The last page"
          },
          "page": {
            "type": "integer",
            "default": 1,
            "description": "The current page"
          },
          "limit": {
            "type": "integer",
            "default": 5,
            "description": "The number of records per page"
          }
        }
      }
    },
    "responses": {
      "200NoData": {
        "description": "No content",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "description": "The response status",
                  "enum": [
                    "success"
                  ]
                },
                "data": {
                  "type": ["object", "null"],
                  "default": null,
                  "description": "The response data"
                }
              }
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["fail"]
                },
                "message": {
                  "type": "string"
                },
                "data": {
                  "type": ["object", "null"],
                  "nullable": true
                }
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "Internal Server Error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["error"]
                },
                "message": {
                  "type": "string"
                },
                "data": {
                  "type": ["object", "null"],
                  "nullable": true
                }
              }
            }
          }
        }
      }
    },
    "parameters": {
      "productIdParam": {
        "name": "id",
        "description": "Product ID",
        "required": true,
        "in": "path",
        "schema": {
          "type": "integer",
          "format": "int32"
        }
      },
      "limitParam": {
        "name": "limit",
        "description": "Number of records per page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "maximum": 100
        },
        "required": false
      },
      "pageParam": {
        "name": "page",
        "description": "Page number of records",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1,
          "minimum": 1
        },
        "required": false
      }
    }
  },
  "tags": [
    {
      "name": "products",
      "description": "Products operations"
    }
  ]
}